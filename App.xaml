<Application x:Class="DarshanPlayer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Dark theme (colors, brushes, control styles) -->
                <ResourceDictionary Source="pack://application:,,,/Themes/DarkTheme.xaml"/>
                <!-- Default language: English -->
                <ResourceDictionary Source="pack://application:,,,/Localization/Lang.en.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Bool → Visibility converter (inline) -->
            <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
